APP_ENV_FILE=deploy/.env.production
COMPOSE_PROJECT_NAME=algowiki
# Local archive example:
# APP_IMAGE=algowiki-web:2026.03.12
# GHCR example:
APP_IMAGE=ghcr.io/nullresot/algowiki-web:latest
APP_IMAGE_REPOSITORY=ghcr.io/nullresot/algowiki-web
GITHUB_REPOSITORY=NullResot/AlgoWiki
GITHUB_BRANCH=main
DEPLOY_SYNC_GITHUB_BRANCH=0
MYSQL_IMAGE=mysql:8.4

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
ALGOWIKI_RELEASE=ghcr-latest
DJANGO_SERVE_FRONTEND=1
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_USE_X_FORWARDED_PORT=1
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
APP_BIND=127.0.0.1
APP_PORT=8001
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
DB_WAIT_TIMEOUT=120
DB_WAIT_INTERVAL=2
DJANGO_REQUEST_LOG_ENABLED=1
DJANGO_SLOW_REQUEST_MS=1500
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_DIR=/srv/algowiki/storage/logs
HEALTH_MIN_DISK_FREE_MB=1024
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=4194304
DATA_UPLOAD_MAX_NUMBER_FIELDS=2000
REGISTER_CAPTCHA_TTL_SECONDS=600
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_LENGTH=6
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_WINDOW_MINUTES=60
EMAIL_CODE_MAX_SENDS_PER_WINDOW=5
EMAIL_CODE_MAX_VERIFY_ATTEMPTS=5
THROTTLE_LOGIN=3/min
THROTTLE_REGISTER=3/hour
THROTTLE_REGISTER_CHALLENGE=12/min
THROTTLE_REGISTER_VERIFY=12/hour
THROTTLE_PASSWORD_RESET_REQUEST=6/hour
THROTTLE_PASSWORD_RESET_CONFIRM=12/hour
THROTTLE_PASSWORD_CHANGE=3/hour
THROTTLE_EMAIL_CHANGE_REQUEST=6/hour
THROTTLE_EMAIL_CHANGE_CONFIRM=12/hour
THROTTLE_PROFILE_UPDATE=3/min
THROTTLE_CONTENT_CREATE=3/min
THROTTLE_CONTENT_UPDATE=3/min
THROTTLE_CONTENT_DELETE=3/min
SITE_NAME=AlgoWiki
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtpdm.aliyun.com
EMAIL_PORT=465
EMAIL_HOST_USER=verify@example.com
EMAIL_HOST_PASSWORD=replace-with-your-smtp-password
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=AlgoWiki <verify@example.com>
SERVER_EMAIL=verify@example.com
EMAIL_SUBJECT_PREFIX=[AlgoWiki]

DB_ENGINE=mysql
DB_HOST=<rds-private-endpoint>
DB_PORT=3306
DB_NAME=algowiki
DB_USER=algowiki
DB_PASSWORD=replace-with-db-password
DB_CHARSET=utf8mb4
DB_CONN_MAX_AGE=300
# Optional for RDS TLS:
# DB_SSL_CA=/etc/ssl/certs/rds-ca.pem

MEDIA_ROOT=/srv/algowiki/media
MEDIA_URL=/media/
FRONTEND_DIST_DIR=/srv/algowiki/frontend/dist

# Optional verification helpers for deploy/server-verify.sh:
# PUBLIC_SITE_URL=https://www.example.com
# PUBLIC_APEX_URL=https://example.com

SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=replace-with-a-random-password
SUPERADMIN_EMAIL=admin@example.com

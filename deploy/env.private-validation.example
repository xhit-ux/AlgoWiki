APP_ENV_FILE=deploy/.env.private-validation
COMPOSE_PROJECT_NAME=algowiki
APP_IMAGE=algowiki-web:validation
MYSQL_IMAGE=mysql:8.4
MYSQL_SERVER_ARGS=--character-set-server=utf8mb4 --collation-server=utf8mb4_unicode_ci

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost
ALGOWIKI_RELEASE=private-validation
DJANGO_SERVE_FRONTEND=1
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_USE_X_FORWARDED_PORT=0
DJANGO_SECURE_PROXY_SSL_HEADER=
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

APP_BIND=127.0.0.1
APP_PORT=8001
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
DB_WAIT_TIMEOUT=120
DB_WAIT_INTERVAL=2

DJANGO_REQUEST_LOG_ENABLED=1
DJANGO_SLOW_REQUEST_MS=1500
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_DIR=/srv/algowiki/storage/logs
HEALTH_MIN_DISK_FREE_MB=512
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=4194304
DATA_UPLOAD_MAX_NUMBER_FIELDS=2000
REGISTER_CAPTCHA_TTL_SECONDS=600
THROTTLE_LOGIN=3/min
THROTTLE_REGISTER=3/hour
THROTTLE_REGISTER_CHALLENGE=12/min
THROTTLE_PASSWORD_CHANGE=3/hour
THROTTLE_PROFILE_UPDATE=3/min
THROTTLE_CONTENT_CREATE=3/min
THROTTLE_CONTENT_UPDATE=3/min
THROTTLE_CONTENT_DELETE=3/min

DB_ENGINE=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=algowiki
DB_USER=algowiki
DB_PASSWORD=replace-with-db-password
DB_CHARSET=utf8mb4
DB_CONN_MAX_AGE=300

MYSQL_DATABASE=algowiki
MYSQL_USER=algowiki
MYSQL_PASSWORD=replace-with-db-password
MYSQL_ROOT_PASSWORD=replace-with-root-password

MEDIA_ROOT=/srv/algowiki/media
MEDIA_URL=/media/
FRONTEND_DIST_DIR=/srv/algowiki/frontend/dist

SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=replace-with-a-random-password
SUPERADMIN_EMAIL=admin@example.com
